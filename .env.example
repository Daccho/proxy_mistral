# Meeting BaaS API
MEETING_BAAS_API_KEY=your_meeting_baas_api_key
MEETING_BAAS_BASE_URL=https://api.meetingbaas.com

# Mistral AI
MISTRAL_API_KEY=your_mistral_api_key

# ElevenLabs
ELEVENLABS_API_KEY=your_elevenlabs_api_key
ELEVENLABS_VOICE_ID=your_voice_id

# Logging
LOG_LEVEL=INFO

# Security (OWASP)
PROXY_MISTRAL_API_KEY=your_api_key_here
PROXY_MISTRAL_WS_TOKEN=your_ws_token_here
ALLOWED_ORIGINS=http://localhost:3000
ENVIRONMENT=development

# Google Calendar (OAuth2)
GOOGLE_CALENDAR_CREDENTIALS=
CALENDAR_POLL_INTERVAL=5
CALENDAR_LOOKAHEAD_MINUTES=15

# Scheduler
SCHEDULER_ENABLED=true
MAX_CONCURRENT_MEETINGS=1
JOIN_BEFORE_START_MINUTES=2
AUTO_LEAVE_AFTER_END_MINUTES=5
DEFAULT_PERSONA=default

# Production: direct WebSocket URL via K8s Ingress (skips tunnel)
PUBLIC_WS_URL=